set nocompatible 	"Désactive la compatibilité avec vi

set nu			"Affiche les numéros de lignes 

syntax on 		"Active la coloration syntaxique

set autoindent

set hls

set t_Co=256

let g:zenburn_high_Contrast = 1

colorscheme zenburn 
